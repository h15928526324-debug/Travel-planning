# --- LLM 配置 ---
OPENAI_API_KEY=sk-e6e3025cef4142668714c8719497bbda
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# --- 天气 API ---
# 使用免费 API (uapis.cn)，无需 Key，零配置可用
# 如需更高精度可替换为和风天气/OpenWeatherMap

# --- 地图/地理编码 API (高德地图) ---
MAP_API_KEY=42393a86bd70248fd5e603c499f3bd81
MAP_API_TYPE=amap

# --- 数据库 (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
